# JARVIS AI OS - Environment Variables Template
# ===============================================
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# ── Logging ────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
JARVIS_LOG_LEVEL=INFO

# Enable debug mode (extra verbose output)
JARVIS_DEBUG=false

# Path for log files (leave empty to log only to console)
JARVIS_LOG_PATH=

# SLO thresholds (infrastructure)
JARVIS_INFRA_SLO_API_P95_MS=1500
JARVIS_INFRA_SLO_API_ERROR_RATE_PCT=5
JARVIS_INFRA_SLO_RUN_COMMAND_P95_MS=30000
JARVIS_INFRA_SLO_CONNECTORS_UNHEALTHY_COUNT=1
JARVIS_INFRA_SLO_AUTOMATION_DEAD_LETTERS_BACKLOG=20
JARVIS_INFRA_SLO_MIN_SAMPLES=20

# ── AI / LLM API Keys ──────────────────────────────────────
# OpenAI API key (required for GPT-based features)
OPENAI_API_KEY=sk-...

# Anthropic API key (required for Claude-based features)
ANTHROPIC_API_KEY=sk-ant-...

# Cohere API key (for hybrid API provider routing)
COHERE_API_KEY=

# ── REST API Interface ─────────────────────────────────────
# Host to bind the API server on
JARVIS_API_HOST=0.0.0.0

# Port for the REST API
JARVIS_API_PORT=8080

# Bearer token for API authentication (set a strong random value)
JARVIS_API_TOKEN=change-me-to-a-strong-secret

# ── Memory & Storage ───────────────────────────────────────
# Directory for persistent memory storage
JARVIS_MEMORY_PATH=./jarvis_memory

# ── Agent System ───────────────────────────────────────────
# Maximum number of concurrent agents
JARVIS_MAX_AGENTS=20

# Default task timeout in seconds
JARVIS_TASK_TIMEOUT=60

# ── Voice Interface ────────────────────────────────────────
# Enable voice interface (requires speech_recognition & pyttsx3)
JARVIS_VOICE_ENABLED=false

# Wake word to activate JARVIS
JARVIS_WAKE_WORD=jarvis

# Speech recognition language code
JARVIS_VOICE_LANGUAGE=en-US

# Text-to-speech speaking rate (words per minute)
JARVIS_TTS_RATE=175

# ── Hybrid Model Routing (Local + API) ─────────────────────
# Enable hybrid router (true/false)
JARVIS_MODEL_ENABLED=true

# Provider selection
# Local: ollama | mlx
JARVIS_MODEL_LOCAL_PROVIDER=ollama
# API: cohere (or leave empty)
JARVIS_MODEL_API_PROVIDER=cohere

# Allow local<->API fallback
JARVIS_MODEL_FALLBACK_ENABLED=true
# Route shadow mode (invoke secondary provider for telemetry only)
JARVIS_MODEL_SHADOW_MODE=false

# Local runtime RAM controls (e.g., 35GB budget on 48GB machine)
JARVIS_MODEL_MEMORY_BUDGET_GB=35
JARVIS_MODEL_TOTAL_MEMORY_GB=48
JARVIS_MODEL_MAX_PARALLEL_MODELS=3
JARVIS_MODEL_AUTO_UNLOAD=true

# Ollama config
JARVIS_MODEL_OLLAMA_BASE_URL=http://127.0.0.1:11434
JARVIS_MODEL_OLLAMA_TEXT_MODEL=qwen2.5:7b
JARVIS_MODEL_OLLAMA_TEXT_MODEL_SIZE_GB=8
# Optional multimodal model slots for later expansion
JARVIS_MODEL_OLLAMA_IMAGE_MODEL=
JARVIS_MODEL_OLLAMA_IMAGE_MODEL_SIZE_GB=12
JARVIS_MODEL_OLLAMA_AUDIO_MODEL=
JARVIS_MODEL_OLLAMA_AUDIO_MODEL_SIZE_GB=8

# Cohere config
JARVIS_MODEL_COHERE_TEXT_MODEL=command-r-plus
JARVIS_MODEL_COHERE_BASE_URL=https://api.cohere.com/v2

# Future MLX / VLMX placeholders
JARVIS_MODEL_MLX_ENABLED=false
JARVIS_MODEL_MLX_TEXT_MODEL=
JARVIS_MODEL_MLX_AUDIO_MODEL=
JARVIS_MODEL_MLX_IMAGE_MODEL=

# ── Production Delivery Engine (Global) ────────────────────
# Turn command-backed gate/deploy execution on/off globally
JARVIS_DELIVERY_COMMAND_EXECUTION_ENABLED=true

# Default command execution controls
JARVIS_DELIVERY_COMMAND_TIMEOUT_SECONDS=120
JARVIS_DELIVERY_MAX_OUTPUT_CHARS=2000
JARVIS_DELIVERY_DEPLOY_MAX_RETRIES=1
JARVIS_DELIVERY_DEPLOY_RETRY_BACKOFF_SECONDS=1

# Comma-separated allowed deploy targets
JARVIS_DELIVERY_ALLOWED_DEPLOY_TARGETS=local,aws,gcp,vercel

# Optional default working directory for gate/deploy commands
JARVIS_DELIVERY_DEFAULT_WORKING_DIR=

# Provider deploy command templates (optional).
# If set, these are used by /api/v1/delivery/releases/run when target matches.
# Example:
# JARVIS_DELIVERY_AWS_DEPLOY_COMMAND=python3 -c "print('deploy aws')"
JARVIS_DELIVERY_LOCAL_DEPLOY_COMMAND=
JARVIS_DELIVERY_AWS_DEPLOY_COMMAND=
JARVIS_DELIVERY_GCP_DEPLOY_COMMAND=
JARVIS_DELIVERY_VERCEL_DEPLOY_COMMAND=
