# JARVIS AI OS - Environment Variables Template
# ===============================================
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# ── Logging ────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
JARVIS_LOG_LEVEL=INFO

# Enable debug mode (extra verbose output)
JARVIS_DEBUG=false

# Path for log files (leave empty to log only to console)
JARVIS_LOG_PATH=

# SLO thresholds (infrastructure)
JARVIS_INFRA_SLO_API_P95_MS=1500
JARVIS_INFRA_SLO_API_ERROR_RATE_PCT=5
JARVIS_INFRA_SLO_RUN_COMMAND_P95_MS=30000
JARVIS_INFRA_SLO_CONNECTORS_UNHEALTHY_COUNT=1
JARVIS_INFRA_SLO_AUTOMATION_DEAD_LETTERS_BACKLOG=20
JARVIS_INFRA_SLO_MIN_SAMPLES=20

# ── AI / LLM API Keys ──────────────────────────────────────
# OpenAI API key (required for GPT-based features)
OPENAI_API_KEY=sk-...

# Anthropic API key (required for Claude-based features)
ANTHROPIC_API_KEY=sk-ant-...

# Cohere API key (for hybrid API provider routing)
COHERE_API_KEY=

# ── REST API Interface ─────────────────────────────────────
# Host to bind the API server on
JARVIS_API_HOST=0.0.0.0

# Port for the REST API
JARVIS_API_PORT=8080

# Bearer token for API authentication (set a strong random value)
JARVIS_API_TOKEN=change-me-to-a-strong-secret

# API performance logging
# Emits readable stage timing logs per request (parse/policy/conversation/governance/total).
JARVIS_API_PERF_LOG_ENABLED=true
# Requests at/above this total latency are logged as WARNING (slow path).
JARVIS_API_PERF_SLOW_MS=1500

# Vision identity registry (multi-person enrollment + recognition)
JARVIS_VISION_IDENTITIES_PATH=data/vision_identities.json
JARVIS_VISION_IDENTITIES_BACKEND=local_deterministic
JARVIS_VISION_IDENTITIES_DIM=128
JARVIS_VISION_IDENTITY_THRESHOLD=0.82
JARVIS_VISION_IDENTITY_SOFT_THRESHOLD=0.68
JARVIS_VISION_IDENTITY_MARGIN=0.02

# World teaching knowledge store
JARVIS_WORLD_KNOWLEDGE_PATH=data/world_knowledge.json

# Realtime stream ingest workers (camera/URL feed processing)
# Lower camera pull rate reduces compute pressure on chat turns.
JARVIS_STREAM_DEFAULT_INTERVAL_MS=2500
JARVIS_STREAM_WORKER_CONCURRENCY=2
JARVIS_STREAM_QUEUE_MAX=256

# LinkedIn MCP connector (optional)
# If set, LinkedIn profile enrichment jobs will call this MCP server first,
# then fall back to web/research methods on failure.
# Example local endpoint (from scripts/linkedin_mcp_server.py):
# JARVIS_LINKEDIN_MCP_ENDPOINT=http://127.0.0.1:8765
JARVIS_LINKEDIN_MCP_ENDPOINT=
JARVIS_LINKEDIN_MCP_TOOL_ENRICH=user-info
JARVIS_LINKEDIN_MCP_AUTH_TOKEN=
# Optional path used by scripts/linkedin_mcp_server.py to load Playwright storage-state JSON.
# Generate with: python3 scripts/bootstrap_linkedin_playwright_auth.py --state-path data/linkedin_storage_state.json
LINKEDIN_STORAGE_STATE_PATH=data/linkedin_storage_state.json
# Optional: use a real local Chrome profile instead of storage-state auth.
# Useful when LinkedIn blocks automation login. Keep Chrome closed when MCP runs.
LINKEDIN_MCP_USE_PERSISTENT_PROFILE=false
LINKEDIN_MCP_CHROME_USER_DATA_DIR=
LINKEDIN_MCP_CHROME_PROFILE_DIR=Default
LINKEDIN_MCP_CHROME_CHANNEL=chrome
LINKEDIN_MCP_HEADLESS=true

# GitHub MCP connector (optional)
# Example:
# JARVIS_GITHUB_MCP_ENDPOINT=http://127.0.0.1:8766
JARVIS_GITHUB_MCP_ENDPOINT=
JARVIS_GITHUB_MCP_TOOL_ENRICH=search_repositories
JARVIS_GITHUB_MCP_AUTH_TOKEN=

# Google Search MCP connector (optional)
# Example:
# JARVIS_GOOGLE_MCP_ENDPOINT=http://127.0.0.1:8767
JARVIS_GOOGLE_MCP_ENDPOINT=
JARVIS_GOOGLE_MCP_TOOL_ENRICH=google_search
JARVIS_GOOGLE_MCP_AUTH_TOKEN=

# Response shaping latency controls
JARVIS_RESPONSE_SINGLE_PASS_ENABLED=true
JARVIS_RESPONSE_HISTORY_WINDOW_SHORT=4
JARVIS_RESPONSE_HISTORY_WINDOW_MEDIUM=6
JARVIS_RESPONSE_HISTORY_WINDOW_LONG=8
JARVIS_QUERY_UNDERSTANDING_ENABLED=true
JARVIS_ADAPTIVE_PLANNING_ENABLED=true
JARVIS_CONFIDENCE_RETRIEVAL_ENABLED=true
JARVIS_MEMORY_SEMANTICS_ENABLED=true
JARVIS_EVAL_TELEMETRY_ENABLED=true
JARVIS_CHAT_DATASET_LOG_ENABLED=true
JARVIS_CHAT_DATASET_LOG_PATH=data/chat_training_events.jsonl
JARVIS_CHAT_DATASET_MAX_CHARS=6000

# ── Memory & Storage ───────────────────────────────────────
# Directory for persistent memory storage
JARVIS_MEMORY_PATH=./jarvis_memory

# Hugging Face cache root. Model downloads default to "$HF_HOME/hub".
HF_HOME=/Volumes/Jiten-2026/AI_SSD/huggingface

# ── Agent System ───────────────────────────────────────────
# Maximum number of concurrent agents
JARVIS_MAX_AGENTS=20

# Agent pools (sub-agents)
JARVIS_AGENT_COORDINATOR_POOL_SIZE=1
JARVIS_AGENT_ANALYST_POOL_SIZE=1
JARVIS_AGENT_DEVELOPER_POOL_SIZE=1
JARVIS_AGENT_MANAGER_POOL_SIZE=1

# Default task timeout in seconds
JARVIS_TASK_TIMEOUT=60

# ── Voice Interface ────────────────────────────────────────
# Enable voice interface (requires speech_recognition & pyttsx3)
JARVIS_VOICE_ENABLED=false

# Wake word to activate JARVIS
JARVIS_WAKE_WORD=jarvis

# Speech recognition language code
JARVIS_VOICE_LANGUAGE=en-US

# Realtime WebSocket STT engine for /api/v1/realtime/.../ws audio_commit
# local_whisper (default) keeps transcription fully local using MLX Whisper.
JARVIS_REALTIME_STT_ENGINE=local_whisper
JARVIS_REALTIME_STT_PYTHON=python3
JARVIS_REALTIME_STT_RUNNER=mlx_whisper.transcribe
JARVIS_REALTIME_STT_MODEL=models--mlx-community--whisper-large-v3-turbo

# Text-to-speech speaking rate (words per minute)
JARVIS_TTS_RATE=175

# ── Hybrid Model Routing (Local + API) ─────────────────────
# Enable hybrid router (true/false)
JARVIS_MODEL_ENABLED=true

# Provider selection
# Local: ollama | mlx
JARVIS_MODEL_LOCAL_PROVIDER=mlx
# API: cohere (or leave empty)
JARVIS_MODEL_API_PROVIDER=cohere

# Allow local<->API fallback
JARVIS_MODEL_FALLBACK_ENABLED=true
# Route shadow mode (invoke secondary provider for telemetry only)
JARVIS_MODEL_SHADOW_MODE=false

# Local runtime RAM controls (e.g., 35GB budget on 48GB machine)
JARVIS_MODEL_MEMORY_BUDGET_GB=35
JARVIS_MODEL_TOTAL_MEMORY_GB=48
JARVIS_MODEL_MAX_PARALLEL_MODELS=3
JARVIS_MODEL_LARGE_MODEL_THRESHOLD_GB=18
JARVIS_MODEL_SINGLE_LARGE_MODEL_MODE=true
JARVIS_MODEL_AUTO_UNLOAD=true
JARVIS_MODEL_KEEP_BASE_MODEL_LOADED=true
# Thermal guard: local models above this parameter-scale hint (e.g. 35B, 40B, 80B)
# are ignored/remapped to smaller alternatives by model_provider_factory.
JARVIS_MAX_LOCAL_MODEL_BILLIONS=34
# Optional explicit base model to pin in memory. Leave empty to auto-select:
# - MLX: JARVIS_MODEL_MLX_TEXT_MODEL_SMALL (fallback JARVIS_MODEL_MLX_TEXT_MODEL)
# - Ollama: JARVIS_MODEL_OLLAMA_TEXT_MODEL
JARVIS_MODEL_BASE_MODEL_NAME=
# If a heavy model cannot fit, allow unloading pinned base model as a last resort.
JARVIS_MODEL_UNLOAD_BASE_WHEN_REQUIRED=true
JARVIS_MODEL_PREWARM_ENABLED=true
JARVIS_MODEL_PREWARM_PROMPT=Reply with just: ready
JARVIS_MODEL_PREWARM_TIMEOUT_SECONDS=8
JARVIS_MODEL_PREWARM_DUAL_TIER=false

# Ask small + large tier for substantive text requests, return small answer first
# and enrich with non-duplicated detail from large tier.
JARVIS_DUAL_TIER_RESPONSE_ENABLED=false

# Ollama config
JARVIS_MODEL_OLLAMA_BASE_URL=http://127.0.0.1:11434
JARVIS_MODEL_OLLAMA_TEXT_MODEL=qwen2.5:7b
JARVIS_MODEL_OLLAMA_TEXT_MODEL_SIZE_GB=8
# Optional multimodal model slots for later expansion
JARVIS_MODEL_OLLAMA_IMAGE_MODEL=
JARVIS_MODEL_OLLAMA_IMAGE_MODEL_SIZE_GB=12
JARVIS_MODEL_OLLAMA_AUDIO_MODEL=
JARVIS_MODEL_OLLAMA_AUDIO_MODEL_SIZE_GB=8

# Cohere config
JARVIS_MODEL_COHERE_TEXT_MODEL=command-r-plus
JARVIS_MODEL_COHERE_BASE_URL=https://api.cohere.com/v2

# MLX / VLMX local runtime
JARVIS_MODEL_MLX_ENABLED=true
JARVIS_MODEL_MLX_TIMEOUT_SECONDS=180
JARVIS_MODEL_MLX_COMMAND_PYTHON=python3
JARVIS_MODEL_MLX_TEXT_RUNNER_MODULE=mlx_lm.generate
JARVIS_MODEL_MLX_IMAGE_RUNNER_MODULE=mlx_vlm.generate
JARVIS_MODEL_MLX_AUDIO_RUNNER_MODULE=mlx_whisper.transcribe
JARVIS_MODEL_MLX_TEMPERATURE=0.2
JARVIS_MODEL_MLX_MAX_TOKENS=2048
JARVIS_MODEL_MLX_DRY_RUN=false
JARVIS_MODEL_MLX_ENABLE_REASONING_MODEL=false
JARVIS_MODEL_MLX_ENABLE_DEEP_RESEARCH_MODEL=false
JARVIS_MODEL_MLX_PERSISTENT_ENABLED=false
JARVIS_MODEL_MLX_PERSISTENT_BASE_URL=http://127.0.0.1:8004
JARVIS_MODEL_MLX_PERSISTENT_ENDPOINT=/v1/chat/completions
JARVIS_MODEL_MLX_PERSISTENT_API_KEY=
JARVIS_MODEL_MLX_PERSISTENT_FALLBACK_CLI=true
JARVIS_MODEL_MLX_TEXT_MODEL=models--Mxfp4-Lab--Qwen3.5-35B-A3B-Claude-4.6-Opus-Distilled-MXFP4-MLX
JARVIS_MODEL_MLX_TEXT_MODEL_SIZE_GB=24
JARVIS_MODEL_MLX_TEXT_MODEL_SMALL=models--mlx-community--Qwen3.5-4B-MLX-4bit
JARVIS_MODEL_MLX_TEXT_MODEL_SMALL_SIZE_GB=4
JARVIS_MODEL_MLX_TEXT_MODEL_CODING=models--mlx-community--Qwen2.5-Coder-14B-Instruct-4bit
JARVIS_MODEL_MLX_TEXT_MODEL_CODING_SIZE_GB=10
JARVIS_MODEL_MLX_TEXT_MODEL_REASONING=models--TheCluster--Qwen3.5-40B-Claude-4.6-Opus-Deckard-Heretic-Uncensored-Thinking-MLX-mxfp4
JARVIS_MODEL_MLX_TEXT_MODEL_REASONING_SIZE_GB=28
JARVIS_MODEL_MLX_TEXT_MODEL_DEEP_RESEARCH=models--lmstudio-community--Qwen3-Next-80B-A3B-Instruct-MLX-4bit
JARVIS_MODEL_MLX_TEXT_MODEL_DEEP_RESEARCH_SIZE_GB=34
JARVIS_MODEL_MLX_IMAGE_MODEL=models--mlx-community--Qwen2-VL-2B-Instruct-4bit
JARVIS_MODEL_MLX_IMAGE_MODEL_SIZE_GB=3
JARVIS_MODEL_MLX_AUDIO_MODEL=models--mlx-community--whisper-large-v3-turbo
JARVIS_MODEL_MLX_AUDIO_MODEL_SIZE_GB=3
JARVIS_MODEL_MLX_RERANKER_MODEL_SMALL=models--Qwen--Qwen3-Reranker-0.6B
JARVIS_MODEL_MLX_RERANKER_MODEL=models--Qwen--Qwen3-Reranker-4B

# ── Production Delivery Engine (Global) ────────────────────
# Turn command-backed gate/deploy execution on/off globally
JARVIS_DELIVERY_COMMAND_EXECUTION_ENABLED=true

# Default command execution controls
JARVIS_DELIVERY_COMMAND_TIMEOUT_SECONDS=120
JARVIS_DELIVERY_MAX_OUTPUT_CHARS=2000
JARVIS_DELIVERY_DEPLOY_MAX_RETRIES=1
JARVIS_DELIVERY_DEPLOY_RETRY_BACKOFF_SECONDS=1

# Comma-separated allowed deploy targets
JARVIS_DELIVERY_ALLOWED_DEPLOY_TARGETS=local,aws,gcp,vercel

# Optional default working directory for gate/deploy commands
JARVIS_DELIVERY_DEFAULT_WORKING_DIR=

# ── Code Assistant ─────────────────────────────────────────
# Colon-separated list of allowed workspace roots for code editing tasks.
# Example: /workspace:/runtime:/Users/you/projects
JARVIS_CODE_ALLOWED_ROOTS=

# Provider deploy command templates (optional).
# If set, these are used by /api/v1/delivery/releases/run when target matches.
# Example:
# JARVIS_DELIVERY_AWS_DEPLOY_COMMAND=python3 -c "print('deploy aws')"
JARVIS_DELIVERY_LOCAL_DEPLOY_COMMAND=
JARVIS_DELIVERY_AWS_DEPLOY_COMMAND=
JARVIS_DELIVERY_GCP_DEPLOY_COMMAND=
JARVIS_DELIVERY_VERCEL_DEPLOY_COMMAND=

# ── Research / RAG / Graph ─────────────────────────────────
JARVIS_RESEARCH_HIERARCHICAL_RAG_ENABLED=true
JARVIS_RESEARCH_RAG_NEIGHBOR_EXPANSION=true
JARVIS_RESEARCH_NEO4J_ENABLED=false
JARVIS_RESEARCH_NEO4J_URI=bolt://127.0.0.1:7687
JARVIS_RESEARCH_NEO4J_USERNAME=neo4j
JARVIS_RESEARCH_NEO4J_PASSWORD=
JARVIS_RESEARCH_NEO4J_DATABASE=neo4j
JARVIS_RESEARCH_LANGGRAPH_ENABLED=false
JARVIS_RESEARCH_LANGGRAPH_MAX_WAVE_SIZE=0
JARVIS_AGENT_WORKFLOW_LANE_CAPS={"developer_lane":2,"analyst_lane":2,"manager_lane":1,"verifier_lane":1}
JARVIS_AGENT_WORKFLOW_LANE_PRIORITY={"verifier_lane":10,"manager_lane":20,"analyst_lane":30,"developer_lane":40}
JARVIS_AGENT_WORKFLOW_STEP_MAX_RETRIES=1
JARVIS_AGENT_WORKFLOW_STEP_RESULT_CONTRACT_STRICT=true
JARVIS_AGENT_TASK_PAYLOAD_CONTRACT_STRICT=true
JARVIS_ORCH_MAX_PENDING_TASKS=2000
JARVIS_AGENT_WORKFLOW_CHECKPOINT_BACKEND=file
JARVIS_AGENT_WORKFLOW_CHECKPOINT_PATH=data/workflow_checkpoints.json
JARVIS_WORKFLOW_CHECKPOINT_RETENTION_DAYS=7
JARVIS_RETENTION_RUN_INTERVAL_SECONDS=300
JARVIS_POLICY_COST_ENABLED=false
JARVIS_POLICY_COST_LEDGER_PATH=data/policy_cost_ledger.json
JARVIS_ADAPTIVE_STRATEGY_ENABLED=false
JARVIS_ADAPTIVE_STRATEGY_STATE_PATH=data/strategy_state.json
JARVIS_ADAPTIVE_STRATEGY_PERSIST_EVERY=10
JARVIS_POOL_CPU_SLOTS=6
JARVIS_POOL_GPU_SLOTS=1
JARVIS_POOL_GPU_ENABLED=true
JARVIS_ARTIFACT_PERSIST_ENABLED=true
JARVIS_ARTIFACT_PERSIST_PATH=data/artifacts
JARVIS_ARTIFACT_RETENTION_DAYS=14
JARVIS_INGRESS_ENABLED=true
JARVIS_INGRESS_MAX_INFLIGHT=32
JARVIS_INGRESS_MAX_QUEUE=128
JARVIS_INGRESS_QUEUE_WAIT_TIMEOUT_MS=3000
JARVIS_TOOL_ISOLATION_ENABLED=true
# Comma-separated absolute roots. Empty means any existing directory.
JARVIS_TOOL_ALLOWED_ROOTS=

# Embedding backend for retrieval:
# local_deterministic (default) | mlx_clip (falls back if unavailable)
JARVIS_RESEARCH_EMBEDDING_BACKEND=local_deterministic
JARVIS_RESEARCH_EMBEDDING_DIM=64
JARVIS_RESEARCH_EMBEDDING_MULTIMODAL_BACKEND=mlx_clip
JARVIS_RESEARCH_EMBEDDING_MULTIMODAL_DIM=64
JARVIS_RESEARCH_RAG_FUSION_TEXT_WEIGHT=0.65
JARVIS_RESEARCH_RAG_FUSION_MULTIMODAL_WEIGHT=0.35
JARVIS_RESEARCH_RAG_RERANKER_ENABLED=true
JARVIS_RESEARCH_RAG_RERANKER_TOP_K=24
JARVIS_RESEARCH_VECTOR_STORE=memory
# Example external SSD path:
# JARVIS_RESEARCH_CHROMA_PATH=/Volumes/Jiten-2026/AI_SSD/ai-research/runtime/research/chroma
JARVIS_RESEARCH_CHROMA_PATH=data/research/chroma
JARVIS_RESEARCH_CHROMA_COLLECTION=jarvis_rag_nodes
JARVIS_RESEARCH_STATE_PATH=data/research/state.json
JARVIS_RESEARCH_MLX_EMBEDDING_TEXT_MODEL=models--mlx-community--Qwen3-Embedding-4B-mxfp8
JARVIS_RESEARCH_MLX_EMBEDDING_TEXT_MODEL_FALLBACK=models--mlx-community--Qwen3-Embedding-0.6B-mxfp8
JARVIS_RESEARCH_MLX_EMBEDDING_IMAGE_MODEL=models--mlx-community--clip-vit-large-patch14
JARVIS_RESEARCH_MLX_RERANKER_MODEL=models--Qwen--Qwen3-Reranker-4B
JARVIS_RESEARCH_MLX_RERANKER_MODEL_FALLBACK=models--Qwen--Qwen3-Reranker-0.6B
