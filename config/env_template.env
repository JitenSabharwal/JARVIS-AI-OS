# JARVIS AI OS - Environment Variables Template
# ===============================================
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# ── Logging ────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
JARVIS_LOG_LEVEL=INFO

# Enable debug mode (extra verbose output)
JARVIS_DEBUG=false

# Path for log files (leave empty to log only to console)
JARVIS_LOG_PATH=

# ── AI / LLM API Keys ──────────────────────────────────────
# OpenAI API key (required for GPT-based features)
OPENAI_API_KEY=sk-...

# Anthropic API key (required for Claude-based features)
ANTHROPIC_API_KEY=sk-ant-...

# ── REST API Interface ─────────────────────────────────────
# Host to bind the API server on
JARVIS_API_HOST=0.0.0.0

# Port for the REST API
JARVIS_API_PORT=8080

# Bearer token for API authentication (set a strong random value)
JARVIS_API_TOKEN=change-me-to-a-strong-secret

# ── Memory & Storage ───────────────────────────────────────
# Directory for persistent memory storage
JARVIS_MEMORY_PATH=./jarvis_memory

# ── Agent System ───────────────────────────────────────────
# Maximum number of concurrent agents
JARVIS_MAX_AGENTS=20

# Default task timeout in seconds
JARVIS_TASK_TIMEOUT=60

# ── Voice Interface ────────────────────────────────────────
# Enable voice interface (requires speech_recognition & pyttsx3)
JARVIS_VOICE_ENABLED=false

# Wake word to activate JARVIS
JARVIS_WAKE_WORD=jarvis

# Speech recognition language code
JARVIS_VOICE_LANGUAGE=en-US

# Text-to-speech speaking rate (words per minute)
JARVIS_TTS_RATE=175
