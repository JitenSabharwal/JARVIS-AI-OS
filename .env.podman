# Copy this file to .env.podman for Podman compose usage.

# Host runtime storage root
JARVIS_RUNTIME_ROOT=/Users/sabharwal/AI_SSD/ai-research/runtime
# API
JARVIS_API_TOKEN=11fa547803ecbbf7714e95b5bcb8e2f9ca8c42723e73d9f76b1a60d70b42e197
JARVIS_DEBUG=false
JARVIS_CODE_ALLOWED_ROOTS=/Users/sabharwal:/Volumes/Jiten-2026/AI_SSD/ai-research/projects
JARVIS_DEFAULT_WORKSPACE_PATH=/Users/sabharwal/Jiten/ai_research/JARVIS-AI-OS

# Host model runtime (Ollama/MLX on macOS host)
JARVIS_MODEL_ENABLED=true
JARVIS_MODEL_LOCAL_PROVIDER=ollama
JARVIS_MODEL_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Research / graph / retrieval
JARVIS_RESEARCH_HIERARCHICAL_RAG_ENABLED=true
JARVIS_RESEARCH_RAG_NEIGHBOR_EXPANSION=true
JARVIS_RESEARCH_NEO4J_ENABLED=true
JARVIS_RESEARCH_NEO4J_URI=bolt://127.0.0.1:7687
JARVIS_RESEARCH_NEO4J_USERNAME=neo4j
JARVIS_RESEARCH_NEO4J_PASSWORD=local-neo4j-password
JARVIS_RESEARCH_NEO4J_DATABASE=neo4j
JARVIS_RESEARCH_LANGGRAPH_ENABLED=true
JARVIS_RESEARCH_EMBEDDING_BACKEND=local_deterministic
JARVIS_RESEARCH_EMBEDDING_DIM=64
JARVIS_RESEARCH_CHROMA_PATH=/Users/sabharwal/AI_SSD/ai-research/runtime/research/chroma

# Runtime backend switches
JARVIS_MEMORY_BACKEND=sqlite
JARVIS_MEMORY_SQLITE_PATH=/Users/sabharwal/AI_SSD/ai-research/runtime/session_memory/jarvis_memory.db
JARVIS_INFRA_MESSAGE_BUS_BACKEND=redis
JARVIS_MEMORY_REDIS_URL=redis://127.0.0.1:6379/0
JARVIS_INFRA_REDIS_URL=redis://127.0.0.1:6379/1

# MCP endpoints (Podman publishes these ports to host)
JARVIS_LINKEDIN_MCP_ENDPOINT=http://127.0.0.1:8765
JARVIS_GITHUB_MCP_ENDPOINT=http://127.0.0.1:8766
JARVIS_GOOGLE_MCP_ENDPOINT=http://127.0.0.1:8767
JARVIS_LINKEDIN_STORAGE_STATE_PATH=/workspace/data/linkedin_storage_state.json
